{
    "$schema": "https://biomejs.dev/schemas/latest/schema.json",

    "formatter": {
        "formatWithErrors": true,
        "useEditorconfig": true,
    },

    "json": {
        "formatter": {
            "indentStyle": "space",
            "indentWidth": 4,
            "trailingCommas": "all",
            "expand": "always",
        },
    },
}
